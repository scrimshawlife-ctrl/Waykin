    {
        double radius = 0.11
        color3f[] primvars:displayColor = [(0.91, 0.85, 0.77)]
        float3 xformOp:scale = (0.48, 0.68, 1.72)
        float3 xformOp:translate = (0.012, 0.59, 0.20)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
