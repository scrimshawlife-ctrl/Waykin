#usda 1.0
(
    defaultPrim = "LiraRoot"
    metersPerUnit = 1
    upAxis = "Y"
    doc = """Waykin Lira AR mid-LOD v1.1 Living Familiar (sculpted prim hierarchy).
A1 Head+Snout, A2 CoreGlow, A3 Filament. Soft asymmetry; spectral not mascot.
Canonical height ~0.72m. Procedural fallback remains permanent safety net."""
)

def Xform "LiraRoot" (
    kind = "component"
)
{
    def Sphere "GroundShadow"
    {
        double radius = 0.18
        color3f[] primvars:displayColor = [(0.05, 0.05, 0.05)]
        float3 xformOp:scale = (1.35, 0.012, 0.92)
        float3 xformOp:translate = (0.01, 0, 0.02)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }

    # Main body mass — slightly forward-leaning, soft oval (not sphere mascot)
    def Sphere "Body"
    {
        double radius = 0.15
        color3f[] primvars:displayColor = [(0.91, 0.85, 0.77)]
        float3 xformOp:scale = (0.68, 1.52, 1.12)
        float3 xformOp:translate = (0.008, 0.29, 0.03)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
