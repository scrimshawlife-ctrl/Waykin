<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Waykin</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSCameraUsageDescription</key>
	<string>Waykin uses the camera to place companions and game events in augmented reality during an active session.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Waykin can optionally read recent walking activity (steps and walking distance) to enrich an active walk. Demo Mode never requires Health access.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Waykin uses your location during an active movement session to measure distance, pace, and route progress.</string>
	<key>UIAppFonts</key>
	<array>
		<string>WaykinDisplay-Regular.ttf</string>
	</array>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- Audio-first walking experience: cues must keep playing with the screen
	     locked and the phone in a pocket. Without this, backgrounding kills audio. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<!-- Presence of UILaunchScreen tells iOS the app supports native full-screen
	     rendering. Without it iOS runs in legacy letterbox (reduced logical size),
	     which shrinks the whole UI and crams ARView into a thin camera band. -->
	<key>UILaunchScreen</key>
	<dict/>
</dict>
</plist>
