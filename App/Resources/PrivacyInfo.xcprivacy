<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Waykin does not track users. No AppTrackingTransparency, no
	     tracking SDKs, zero third-party dependencies. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!-- The app collects no data that leaves the device. Health is
	     read-only on-device enrichment; location drives on-device movement
	     and user-initiated MapKit search/routing (handled by Apple's
	     service). See KNOWN_LIMITATIONS: no remote analytics or upload. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<!-- Required-reason API declarations. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- Skin, appearance, and glance-flag preferences via
			     UserDefaults, accessing only this app's own defaults. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
